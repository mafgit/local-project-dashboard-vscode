{
  "name": "localhub",
  "displayName": "LocalHub",
  "description": "Open projects in a new tab without having to find folders in explorer",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:sidebarView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "localhub.openProject",
        "title": "LocalHub: Open A Project In New Window"
      },
      {
        "command": "localhub.refreshDirectories",
        "title": "LocalHub: Refresh Directories"
      },
      {
        "command": "localhub.showProjectsPanel",
        "title": "LocalHub: Open Projects View"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sidebarViewContainer",
          "title": "LocalHub",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "sidebarViewContainer": [
        {
          "type": "webview",
          "id": "sidebarView",
          "name": "LocalHub",
          "icon": "media/icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.104.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
